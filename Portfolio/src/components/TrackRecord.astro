---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const records = await getCollection("trackrecords");
// 日付で降順（新しい順）にソート
records.sort((a, b) => b.data.date.localeCompare(a.data.date));

let baseUrl = import.meta.env.BASE_URL;
if (!baseUrl.endsWith("/")) baseUrl += "/";

// 画像パスを解決するヘルパー
const resolveImagePath = (path: string) => {
    if (path.startsWith('http')) return path;
    const cleanPath = path.startsWith('/') ? path.slice(1) : path;
    // baseUrlを考慮したフルパスを返す
    return `${baseUrl}${cleanPath}`;
};
---
<section class="track-record">
    <h2 class="section-title">Achievements <small>// TRACK RECORD</small></h2>
    <div class="record-list">
        {records.map((record) => (
            <div 
                class="mil-border record-item clickable" 
                data-title={record.data.title}
                data-date={record.data.date}
                data-grantor={record.data.grantor}
                data-desc={record.data.description}
                data-image={resolveImagePath(record.data.image)}
            >
                {record.data.image && (
                    <div class="record-image">
                        <Image 
                            src={resolveImagePath(record.data.image)} 
                            alt={record.data.title}
                            width={150}
                            height={150}
                            format="webp"
                            quality={80}
                        />
                    </div>
                )}
                <div class="record-content">
                    <div class="record-meta">
                        <span class="date">{record.data.date}</span>
                        <span class="grantor">{record.data.grantor}</span>
                    </div>
                    <h3 class="record-title">{record.data.title}</h3>
                    <p class="record-description">{record.data.description}</p>
                </div>
                <div class="click-hint">VIEW DETAILS >></div>
            </div>
        ))}
    </div>

    <!-- Modal Structure -->
    <div id="record-modal" class="modal">
        <div class="modal-backdrop"></div>
        <div class="mil-border modal-content">
            <button id="modal-close" class="modal-close">&times;</button>
            <div class="modal-body">
                <div id="modal-image-container" class="modal-image"></div>
                <div class="modal-info">
                    <div class="modal-meta">
                        <span id="modal-date" class="date"></span>
                        <span id="modal-grantor" class="grantor"></span>
                    </div>
                    <h3 id="modal-title" class="record-title"></h3>
                    <div class="mil-border-top separator"></div>
                    <p id="modal-desc" class="record-description"></p>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    const modal = document.getElementById('record-modal');
    const modalContent = modal?.querySelector('.modal-content');
    const closeBtn = document.getElementById('modal-close');
    const backdrop = modal?.querySelector('.modal-backdrop');
    
    const mTitle = document.getElementById('modal-title');
    const mDate = document.getElementById('modal-date');
    const mGrantor = document.getElementById('modal-grantor');
    const mDesc = document.getElementById('modal-desc');
    const mImageContainer = document.getElementById('modal-image-container');

    const openModal = (data) => {
        if (!modal || !mTitle || !mDate || !mGrantor || !mDesc || !mImageContainer) return;
        
        mTitle.textContent = data.title;
        mDate.textContent = data.date;
        mGrantor.textContent = data.grantor;
        mDesc.textContent = data.desc;
        
        if (data.image) {
            // Encode the path to handle Japanese characters/spaces
            const encodedImage = encodeURI(data.image);
            mImageContainer.innerHTML = `<img src="${encodedImage}" alt="${data.title}" />`;
            mImageContainer.style.display = 'flex';
        } else {
            mImageContainer.style.display = 'none';
        }

        modal.classList.add('active');
        document.body.style.overflow = 'hidden'; // Prevent scroll
    };

    const closeModal = () => {
        modal?.classList.remove('active');
        document.body.style.overflow = '';
    };

    document.querySelectorAll('.record-item.clickable').forEach(item => {
        item.addEventListener('click', () => {
            const data = (item as HTMLElement).dataset;
            openModal(data);
        });
    });

    closeBtn?.addEventListener('click', closeModal);
    backdrop?.addEventListener('click', closeModal);
    
    // Close on Escape key
    window.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeModal();
    });
</script>

<style>
    .section-title {
        font-size: 1.8rem;
        margin-bottom: 30px;
        border-left: 5px solid var(--accent-color);
        padding-left: 15px;
        color: var(--accent-color);
    }

    .section-title small {
        font-size: 0.9rem;
        color: var(--text-sub);
    }

    .record-list {
        display: flex;
        flex-direction: column;
        gap: 25px;
    }

    .record-item {
        position: relative;
        display: flex;
        gap: 20px;
        background: rgba(18, 18, 18, 0.7); /* 赤みを排除し、不透明度を調整 */
        overflow: hidden;
        transition: transform 0.3s ease, background 0.3s ease;
    }

    .record-item.clickable {
        cursor: pointer;
    }

    .record-item.clickable:hover {
        background: rgba(var(--accent-color-rgb), 0.1);
        transform: translateX(10px);
        box-shadow: -5px 0 0 var(--accent-color);
    }

    @media (max-width: 768px) {
        .record-item {
            flex-direction: column;
            gap: 0;
        }
    }

    .record-image {
        width: 150px;
        min-width: 150px;
        height: 150px; /* 1:1 ratio */
        border-right: 1px solid rgba(var(--accent-color-rgb), 0.2);
        background: #000;
        overflow: hidden;
    }

    @media (max-width: 768px) {
        .record-image {
            width: 100%;
            height: 250px;
            border-right: none;
            border-bottom: 1px solid rgba(var(--accent-color-rgb), 0.2);
        }
    }


    .record-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.7;
        transition: opacity 0.3s ease, transform 0.3s ease;
    }

    .record-item:hover .record-image img {
        opacity: 1;
        transform: scale(1.05);
    }

    .record-content {
        padding: 20px;
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .record-meta {
        display: flex;
        justify-content: space-between;
        margin-bottom: 8px;
        font-size: 0.8rem;
    }

    .date {
        color: var(--accent-glow);
        font-family: monospace;
        font-weight: bold;
    }

    .grantor {
        color: var(--text-sub);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .record-title {
        font-size: 1.2rem;
        color: #fff;
        margin-bottom: 8px;
    }

    .record-description {
        font-size: 0.9rem;
        color: var(--text-main);
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .click-hint {
        position: absolute;
        bottom: 10px;
        right: 15px;
        font-size: 0.7rem;
        color: var(--accent-color);
        opacity: 0;
        transition: opacity 0.3s ease;
        font-weight: bold;
    }

    .record-item:hover .click-hint {
        opacity: 0.8;
    }

    /* Modal Styles */
    .modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 2000;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease;
    }

    .modal.active {
        opacity: 1;
        pointer-events: auto;
    }

    .modal-backdrop {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.85);
        backdrop-filter: blur(5px);
    }

    .modal-content {
        position: relative;
        width: 90%;
        max-width: 700px;
        max-height: 85vh;
        background: var(--panel-color);
        z-index: 2001;
        overflow-y: auto;
        animation: modalSlide 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @keyframes modalSlide {
        from { transform: translateY(30px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }

    .modal-close {
        position: absolute;
        top: 20px;
        right: 20px;
        background: rgba(0, 0, 0, 0.7);
        border: 1px solid var(--accent-color);
        color: #fff;
        width: 44px;
        height: 44px;
        font-size: 1.8rem;
        cursor: pointer;
        z-index: 2010;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        border-radius: 50%;
        line-height: 1;
        padding-bottom: 4px; /* Adjust X alignment */
    }

    .modal-close:hover {
        background: var(--accent-color);
        color: #000;
        box-shadow: 0 0 15px var(--accent-color);
    }

    .modal-image {
        width: 100%;
        aspect-ratio: 1 / 1; /* Force 1:1 ratio */
        max-width: 500px; /* Limit size so it doesn't take over the screen */
        margin: 0 auto; /* Center horizontally */
        background: #000;
        border-bottom: 1px solid rgba(var(--accent-color-rgb), 0.3);
        display: flex;
        justify-content: center;
        align-items: center;
        overflow: hidden;
    }

    .modal-image img {
        width: 100%;
        height: 100%;
        object-fit: contain; /* Show the whole image inside the square */
        display: block;
    }

    .modal-info {
        padding: 30px;
    }

    .separator {
        height: 1px;
        margin: 20px 0;
        border-top: 1px solid rgba(var(--accent-color-rgb), 0.3);
    }

    .modal-info .record-description {
        display: block; /* Show full text */
        -webkit-line-clamp: unset;
        font-size: 1rem;
        line-height: 1.8;
    }

    .modal-info .record-title {
        font-size: 1.6rem;
    }
</style>
