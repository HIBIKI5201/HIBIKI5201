---
---
<section class="track-record">
    <h2 class="section-title">Operational Excellence <small>// TRACK RECORD</small></h2>
    <div class="records">
        <div class="mil-border record-entry">
            <div class="category">AWARD</div>
            <div class="content">受賞歴・実績などをここに記載</div>
        </div>
        <div class="mil-border record-entry">
            <div class="category">TALK</div>
            <div class="content">登壇歴などをここに記載</div>
        </div>
    </div>
</section>

<style>
    .section-title {
        font-size: 1.8rem;
        margin-bottom: 30px;
        border-left: 5px solid var(--accent-color);
        padding-left: 15px;
        color: var(--accent-color);
    }

    .section-title small {
        font-size: 0.9rem;
        color: var(--text-sub);
    }

    .records {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .record-entry {
        display: flex;
        gap: 20px;
        align-items: center;
    }

    .category {
        font-weight: bold;
        color: var(--accent-color);
        min-width: 120px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
</style>
