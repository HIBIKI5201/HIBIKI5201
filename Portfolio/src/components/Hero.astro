---
// 自己紹介セクション。サイト訪問者に最初に目に入る部分で、自己紹介や主要な情報を表示する。

function getExperience(startDate: string) {
    const start = new Date(startDate);
    const today = new Date();

    let years = today.getFullYear() - start.getFullYear();
    let months = today.getMonth() - start.getMonth();

    // 日付がまだ来ていない場合は1か月引く。
    if (today.getDate() < start.getDate()) {
        months--;
    }

    // 月がマイナスになったら年から借りる。
    if (months < 0) {
        years--;
        months += 12;
    }

    return `${years}Y${months}M`;
}

const unityExp = getExperience("2024-01-01");
const csharpExp = getExperience("2024-04-01");
const unrealExp = getExperience("2025-04-01");
const cppExp = getExperience("2025-07-01");
---

<header class="hero mil-border">
    <div class="status-indicator">PORTFOLIO ONLINE: SYSTEM STABLE</div>
    <h1>八幡 拓音 <small>TAKUTO YAHATA</small></h1>
    <div class="affiliation">
        <span class="tag">AFFILIATION</span>
        バンタンゲームアカデミー東京校 / 星槎大学
    </div>
    <div class="role">
        <span class="tag">ROLE</span>
        ゲームプログラマー専攻
    </div>
    <div class="tech-stack">
    <span class="tech-item">Unity [{unityExp}]</span>
    <span class="tech-item">C# [{csharpExp}]</span>
    <span class="tech-item">UnrealEngine [{unrealExp}]</span>
    <span class="tech-item">C++ [{cppExp}]</span>
    </div>
</header>

<style>
    header {
        padding: 40px;
        margin-top: 20px;
        margin-bottom: 40px;
    }

    h1 {
        font-size: 3rem;
        margin: 10px 0;
        color: #fff;
    }

    h1 small {
        font-size: 1rem;
        display: block;
        opacity: 0.6;
        font-weight: 300;
    }

    .status-indicator {
        font-size: 0.8rem;
        color: var(--accent-color);
        font-weight: bold;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .status-indicator::before {
        content: "";
        width: 10px;
        height: 10px;
        background: var(--accent-color);
        border-radius: 50%;
        display: inline-block;
        box-shadow: 0 0 10px var(--accent-color);
        animation: blink 1.5s infinite;
    }

    @keyframes blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.3; }
    }

    .affiliation, .role {
        margin: 10px 0;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .tag {
        background: var(--military-purple);
        color: #fff;
        font-size: 0.7rem;
        padding: 2px 8px;
        border-radius: 2px;
    }

    .tech-stack {
        margin-top: 20px;
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .tech-item {
        border: 1px solid var(--accent-color);
        padding: 4px 12px;
        font-size: 0.9rem;
        color: var(--accent-color);
        background: rgba(var(--accent-color-rgb), 0.1);
    }
</style>
