<style>
    .section-title {
        font-size: 1.8rem;
        margin-bottom: 30px;
        border-left: 5px solid var(--accent-color);
        padding-left: 15px;
        color: var(--accent-color);
    }

    .section-title small {
        font-size: 0.9rem;
        color: var(--text-sub);
    }

    .grid-links {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 15px;
    }

    .link-item {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 15px;
        font-weight: bold;
        background: rgba(26, 20, 20, 0.6);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        text-decoration: none;
        color: var(--text-main);
    }

    .link-item:hover {
        background: rgba(188, 76, 255, 0.1);
        transform: translateY(-3px);
        box-shadow: 0 5px 15px rgba(188, 76, 255, 0.2);
        color: var(--accent-color);
    }

    .icon {
        width: 20px;
        height: 20px;
    }

    .mt { margin-top: 20px; }

    .notion-links {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 20px;
    }

    .major-link {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 30px;
        text-align: center;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        text-decoration: none;
        background: rgba(26, 20, 20, 0.6);
    }

    .major-icon {
        width: 40px;
        height: 40px;
        margin-bottom: 15px;
        color: var(--accent-color);
    }

    .major-link.warning {
        border-color: var(--accent-color);
    }

    .major-link.warning .label {
        color: var(--accent-color);
        font-size: 1.4rem;
        font-weight: bold;
        margin-bottom: 5px;
    }

    .major-link.warning .url {
        color: var(--text-sub);
        font-size: 0.9rem;
    }

    .major-link.warning:hover {
        transform: scale(1.02);
        background: rgba(188, 76, 255, 0.1);
        box-shadow: 0 0 30px rgba(188, 76, 255, 0.2);
    }
</style>
