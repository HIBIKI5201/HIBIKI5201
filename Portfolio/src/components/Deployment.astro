<style>
    .section-title {
        font-size: 1.8rem;
        margin-bottom: 30px;
        border-left: 5px solid var(--accent-color);
        padding-left: 15px;
        color: var(--accent-color);
    }

    .section-title small {
        font-size: 0.9rem;
        color: var(--text-sub);
    }

    .grid-links {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 15px;
    }

    .link-item {
        display: block;
        text-align: center;
        padding: 15px;
        font-weight: bold;
        background: rgba(255, 255, 255, 0.05);
    }

    .mt { margin-top: 20px; }

    .major-link {
        display: flex;
        flex-direction: column;
        padding: 25px;
        text-align: center;
        margin-bottom: 20px;
        transition: transform 0.2s;
    }

    .major-link.warning {
        border-color: var(--warning-color);
    }

    .major-link.warning .label {
        color: var(--warning-color);
        font-size: 1.4rem;
        font-weight: bold;
    }

    .major-link.warning:hover {
        transform: scale(1.02);
        background: rgba(255, 171, 0, 0.1);
    }
</style>
