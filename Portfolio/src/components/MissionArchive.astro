---
import { getCollection } from "astro:content";

const missions = await getCollection("projects");
missions.sort((a, b) => b.data.date.localeCompare(a.data.date));

let baseUrl = import.meta.env.BASE_URL;
if (!baseUrl.endsWith("/")) baseUrl += "/";
---

<section class="mission-archive">
    <h2 class="section-title">MISSION ARCHIVE <small>// GAME PROJECTS</small></h2>
    
    <div class="mission-grid">
        {missions.map((mission) => (
            <a href={`${baseUrl}projects/${mission.slug}/`} class="mission-link">
                <div class="mil-border mission-item">
                    {mission.data.thumbnail && (
                        <div class="mission-thumbnail">
                            <img src={mission.data.thumbnail} alt={mission.data.title} loading="lazy" />
                        </div>
                    )}
                    <div class="mission-content">
                        <div class="mission-header">
                            <span class="id">{mission.data.projectCode}</span>
                            <span class={`status ${mission.data.status.toLowerCase()}`}>{mission.data.status}</span>
                        </div>
                        <h3>{mission.data.title}</h3>
                        <div class="meta">
                            <span class="date">{mission.data.date}</span>
                            <div class="tags">
                                {mission.data.stack.map(s => <span class="tag stack">{s}</span>)}
                                {mission.data.technologies.map(t => <span class="tag tech">{t}</span>)}
                                {mission.data.tools && mission.data.tools.map(tool => <span class="tag tool">{tool}</span>)}
                            </div>
                        </div>
                        <p class="desc">{mission.data.description}</p>
                        <div class="entry-btn">ENTRY LOG ACCESS >></div>
                    </div>
                </div>
            </a>
        ))}
    </div>
</section>

<style>
    .mission-archive {
        margin: 120px 0;
        padding: 40px 0;
        border-top: 1px solid rgba(255, 18, 18, 0.2);
        border-bottom: 1px solid rgba(255, 18, 18, 0.2);
    }

    .section-title {
        font-size: 2.2rem;
        margin-bottom: 50px;
        border-left: 8px solid var(--accent-color);
        padding-left: 20px;
        color: var(--accent-color);
        letter-spacing: 0.1em;
    }

    .section-title small {
        font-size: 1rem;
        color: var(--text-sub);
        font-weight: normal;
        margin-left: 10px;
    }

    .mission-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 20px;
    }

    .mission-link {
        text-decoration: none;
        color: inherit;
        display: block;
    }

    .mission-item {
        background: rgba(26, 20, 20, 0.4);
        transition: transform 0.2s, background 0.2s, box-shadow 0.2s;
        cursor: pointer;
        display: flex;
        flex-direction: row;
        gap: 0;
        overflow: hidden;
    }

    @media (max-width: 768px) {
        .mission-item {
            flex-direction: column;
        }
    }

    .mission-thumbnail {
        width: 300px;
        min-width: 300px;
        height: auto;
        overflow: hidden;
        border-right: 1px solid rgba(255, 18, 18, 0.2);
        background: #000;
    }

    @media (max-width: 768px) {
        .mission-thumbnail {
            width: 100%;
            height: 200px;
            border-right: none;
            border-bottom: 1px solid rgba(255, 18, 18, 0.2);
        }
    }

    .mission-thumbnail img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.8;
        transition: transform 0.3s, opacity 0.3s;
    }

    .mission-link:hover .mission-thumbnail img {
        transform: scale(1.05);
        opacity: 1;
    }

    .mission-content {
        padding: 20px;
        flex-grow: 1;
    }

    .mission-link:hover .mission-item {
        background: rgba(255, 18, 18, 0.1);
        transform: translateX(10px);
        box-shadow: -5px 0 0 var(--accent-color);
    }

    .mission-header {
        display: flex;
        justify-content: space-between;
        margin-bottom: 10px;
        font-size: 0.8rem;
        font-weight: bold;
    }

    .id {
        color: var(--accent-color);
        border: 1px solid var(--accent-color);
        padding: 2px 8px;
    }

    .status {
        padding: 2px 8px;
        border-radius: 2px;
        color: #fff;
    }

    .status.active { background: #ff1212; }
    .status.completed { background: #1e90ff; }
    .status.archived { background: #888; }

    h3 {
        font-size: 1.3rem;
        margin-bottom: 10px;
        color: #fff;
    }

    .meta {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 15px;
        font-size: 0.8rem;
    }

    .date {
        color: var(--warning-color);
        font-family: monospace;
    }

    .tags {
        display: flex;
        gap: 8px;
        flex-wrap: nowrap;
        overflow-x: auto;
        padding-bottom: 5px;
        -webkit-overflow-scrolling: touch;
    }

    /* Hide scrollbar for clean look but keep functionality */
    .tags::-webkit-scrollbar {
        height: 3px;
    }
    .tags::-webkit-scrollbar-thumb {
        background: rgba(255, 18, 18, 0.3);
    }

    .tag {
        flex: 0 0 auto;
        color: var(--accent-color);
        background: rgba(255, 18, 18, 0.1);
        border: 1px solid rgba(255, 18, 18, 0.3);
        padding: 1px 8px;
        font-size: 0.75rem;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .tag.stack::before { content: ":: "; opacity: 0.6; }
    
    .tag.tech {
        color: var(--warning-color);
        background: rgba(255, 171, 0, 0.1);
        border-color: rgba(255, 171, 0, 0.3);
    }
    .tag.tech::before { content: "> "; opacity: 0.6; }

    .tag.tool {
        color: var(--text-sub);
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.1);
    }
    .tag.tool::before { content: "+ "; opacity: 0.6; }

    .desc {
        font-size: 0.9rem;
        line-height: 1.6;
        color: var(--text-main);
        margin-bottom: 20px;
        white-space: pre-wrap;
    }

    .entry-btn {
        text-align: right;
        font-size: 0.7rem;
        color: var(--accent-color);
        font-weight: bold;
        opacity: 0.6;
        transition: all 0.3s ease;
        letter-spacing: 0.1em;
    }

    .mission-link:hover .entry-btn {
        opacity: 1;
        text-shadow: 0 0 8px var(--accent-color), 0 0 15px var(--accent-color);
        transform: scale(1.05);
        color: #fff;
    }
</style>
