---
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<header class="hero mil-border">
		<div class="status-indicator">SYSTEM ONLINE: ACTIVE</div>
		<h1>八幡 拓音 <small>TAKUTO YAHATA</small></h1>
		<div class="affiliation">
			<span class="tag">AFFILIATION</span>
			バンタンゲームアカデミー東京校 / 星槎大学 大学域
		</div>
		<div class="role">
			<span class="tag">SPEC</span>
			ゲームプログラマー専攻
		</div>
		<div class="tech-stack">
			<span class="tech-item">Unity [1Y5M]</span>
			<span class="tech-item">C# [1Y2M]</span>
			<span class="tech-item">UnrealEngine [1M]</span>
		</div>
	</header>

	<section class="profile">
		<h2 class="section-title">Tactical Intel <small>// PROFILE</small></h2>
		<div class="grid-2">
			<div class="mil-border card">
				<h3>Interests</h3>
				<p>ゲーム研究、ストーリー考察、勉強会、ボーイスカウト</p>
			</div>
			<div class="mil-border card">
				<h3>Preferred Genres</h3>
				<p>TPS、RTS、シミュレーション</p>
			</div>
		</div>
		<div class="mil-border card mt">
			<h3>Combat Training (Skills)</h3>
			<div class="skill-bar"><div class="fill" style="width: 85%">Unity / C#</div></div>
			<div class="skill-bar"><div class="fill" style="width: 25%">Unreal Engine</div></div>
		</div>
		<div class="mil-border card mt">
			<h3>Favorite Operations (Games)</h3>
			<p>Warframe、メタルギアシリーズ、ドールズフロントライン</p>
		</div>
	</section>

	<section class="career">
		<h2 class="section-title">Mission Log <small>// CAREER</small></h2>
		<div class="timeline">
			<div class="mil-border log-entry">
				<div class="time">2024 ~ Present</div>
				<div class="content">バンタンゲームアカデミー 4年制大学部プログラマー専攻</div>
			</div>
			<div class="mil-border log-entry">
				<div class="time">2021 ~ 2023</div>
				<div class="content">N/S高等学校 オンライン通学コース</div>
			</div>
		</div>
	</section>

	<section class="deployment">
		<h2 class="section-title">Deployment Hub <small>// LINKS & WORKS</small></h2>
		<div class="grid-links">
			<a href="https://x.com/HIBIKI_5201dev" target="_blank" class="mil-border link-item">Twitter [X]</a>
			<a href="https://github.com/HIBIKI5201" target="_blank" class="mil-border link-item">GitHub</a>
			<a href="https://qiita.com/takuto5201" target="_blank" class="mil-border link-item">Qiita</a>
			<a href="https://www.youtube.com/channel/UCKPNA5jfKfMEkj-Z49JU-3Q" target="_blank" class="mil-border link-item">YouTube</a>
		</div>
		
		<div class="notion-links mt">
			<a href="https://www.notion.so/1564374a1f768022a6b2cbd7ef189e67?pvs=21" target="_blank" class="mil-border major-link warning">
				<span class="label">MAIN PORTFOLIO</span>
				<span class="url">Access Notion Database</span>
			</a>
			<a href="https://www.notion.so/20c4374a1f76801585ddebbb1774a7e4?pvs=21" target="_blank" class="mil-border major-link warning">
				<span class="label">AWARDS & ACHIEVEMENTS</span>
				<span class="url">Review Mission Records</span>
			</a>
		</div>
	</section>

	<footer class="mil-border">
		<p>&copy; 2026 TAKUTO YAHATA. ALL SYSTEMS OPERATIONAL.</p>
	</footer>
</Layout>

<style>
	header {
		padding: 40px;
		margin-top: 20px;
		margin-bottom: 40px;
	}

	h1 {
		font-size: 3rem;
		margin: 10px 0;
		color: #fff;
	}

	h1 small {
		font-size: 1rem;
		display: block;
		opacity: 0.6;
		font-weight: 300;
	}

	.status-indicator {
		font-size: 0.8rem;
		color: var(--accent-color);
		font-weight: bold;
		display: flex;
		align-items: center;
		gap: 10px;
	}

	.status-indicator::before {
		content: "";
		width: 10px;
		height: 10px;
		background: var(--accent-color);
		border-radius: 50%;
		display: inline-block;
		box-shadow: 0 0 10px var(--accent-color);
		animation: blink 1.5s infinite;
	}

	@keyframes blink {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.3; }
	}

	.affiliation, .role {
		margin: 10px 0;
		display: flex;
		align-items: center;
		gap: 15px;
	}

	.tag {
		background: var(--military-green);
		color: #fff;
		font-size: 0.7rem;
		padding: 2px 8px;
		border-radius: 2px;
	}

	.tech-stack {
		margin-top: 20px;
		display: flex;
		gap: 10px;
		flex-wrap: wrap;
	}

	.tech-item {
		border: 1px solid var(--accent-color);
		padding: 4px 12px;
		font-size: 0.9rem;
		color: var(--accent-color);
		background: rgba(118, 255, 3, 0.1);
	}

	.section-title {
		font-size: 1.8rem;
		margin-bottom: 30px;
		border-left: 5px solid var(--accent-color);
		padding-left: 15px;
		color: var(--accent-color);
	}

	.section-title small {
		font-size: 0.9rem;
		color: var(--text-sub);
	}

	.grid-2 {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 20px;
	}

	@media (max-width: 600px) {
		.grid-2 { grid-template-columns: 1fr; }
	}

	.card h3 {
		font-size: 1.1rem;
		margin-bottom: 15px;
		color: var(--accent-color);
		border-bottom: 1px solid rgba(118, 255, 3, 0.2);
		padding-bottom: 5px;
	}

	.mt { margin-top: 20px; }

	.skill-bar {
		height: 12px;
		background: rgba(255, 255, 255, 0.1);
		margin-bottom: 15px;
		position: relative;
		border: 1px solid rgba(255, 255, 255, 0.2);
	}

	.skill-bar .fill {
		height: 100%;
		background: var(--accent-color);
		display: flex;
		align-items: center;
		padding-left: 10px;
		font-size: 0.7rem;
		color: #000;
		font-weight: bold;
		white-space: nowrap;
	}

	.timeline {
		display: flex;
		flex-direction: column;
		gap: 20px;
	}

	.log-entry {
		display: flex;
		gap: 20px;
		align-items: center;
	}

	.time {
		font-weight: bold;
		color: var(--accent-color);
		min-width: 120px;
	}

	.grid-links {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
		gap: 15px;
	}

	.link-item {
		display: block;
		text-align: center;
		padding: 15px;
		font-weight: bold;
		background: rgba(255, 255, 255, 0.05);
	}

	.major-link {
		display: flex;
		flex-direction: column;
		padding: 25px;
		text-align: center;
		margin-bottom: 20px;
		transition: transform 0.2s;
	}

	.major-link.warning {
		border-color: var(--warning-color);
	}

	.major-link.warning .label {
		color: var(--warning-color);
		font-size: 1.4rem;
		font-weight: bold;
	}

	.major-link.warning:hover {
		transform: scale(1.02);
		background: rgba(255, 171, 0, 0.1);
	}

	footer {
		text-align: center;
		padding: 20px;
		font-size: 0.8rem;
		opacity: 0.6;
		margin-top: 60px;
	}
</style>
