---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const missions = await getCollection("projects");
  return missions.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// BASE_URLの末尾に / があるかを確認し、無ければ付けます
let baseUrl = import.meta.env.BASE_URL;
if (!baseUrl.endsWith("/")) baseUrl += "/";
---

<Layout title={`${entry.data.title} - PROJECT DETAILS`}>
    <div class="mission-detail-container">
        <a href={baseUrl} class="back-btn"><< RETURN TO HOME</a>
        
        <header class="mil-border detail-header">
            <div class="header-top">
                <span class="id">{entry.data.projectCode}</span>
                <span class={`type ${entry.data.productionType.toLowerCase()}`}>
                    {entry.data.productionType === 'SOLO' ? 'Solo' : 
                     entry.data.productionType === 'TEAM' ? 'Team' : 'Other'}
                </span>
            </div>
            <h1>{entry.data.title}</h1>
            <div class="meta">
                <span class="label">DATE:</span> {entry.data.date}
                
                <div class="spec-sheet">
                    <div class="spec-row">
                        <span class="spec-label">CORE STACK</span>
                        <div class="tags">
                            {entry.data.stack.map(s => <span class="tag stack">{s}</span>)}
                        </div>
                    </div>
                    <div class="spec-row">
                        <span class="spec-label">TECHNOLOGIES</span>
                        <div class="tags">
                            {entry.data.technologies.map(t => <span class="tag tech">{t}</span>)}
                        </div>
                    </div>
                    {entry.data.tools && entry.data.tools.length > 0 && (
                        <div class="spec-row">
                            <span class="spec-label">TOOLS & LIBRARIES</span>
                            <div class="tags">
                                {entry.data.tools.map(tool => <span class="tag tool">{tool}</span>)}
                            </div>
                        </div>
                    )}
                </div>
            </div>
        </header>

        {entry.data.thumbnail && (
            <div class="mission-hero mil-border">
                <img src={entry.data.thumbnail.startsWith('http') ? entry.data.thumbnail : `${import.meta.env.BASE_URL.replace(/\/$/, '')}/${entry.data.thumbnail.replace(/^\//, '')}`} alt={entry.data.title} class="hero-image" />
            </div>
        )}

        <section class="mil-border intel-module">
            <div class="intel-grid">
                <div class="intel-main">
                    <div class="asset-label">// PROJECT OVERVIEW</div>
                    <div class="overview-content">
                        {entry.data.overview || entry.data.description}
                    </div>
                </div>

                {(entry.data.videoUrl || entry.data.releaseUrl || entry.data.repoUrl) && (
                    <div class="intel-side">
                        {entry.data.videoUrl && (
                            <div class="intel-asset-box">
                                <div class="asset-label">// DEMO VIDEO</div>
                                <div class="video-container">
                                    {entry.data.videoUrl.includes('youtube.com') || entry.data.videoUrl.includes('youtu.be') ? (
                                        <iframe 
                                            src={entry.data.videoUrl.replace('watch?v=', 'embed/').replace('youtu.be/', 'youtube.com/embed/')} 
                                            title="Project Demo"
                                            frameborder="0" 
                                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                                            allowfullscreen
                                        ></iframe>
                                    ) : (
                                        <a href={entry.data.videoUrl} target="_blank" class="asset-link-btn">WATCH DEMO >></a>
                                    )}
                                </div>
                            </div>
                        )}

                        {(entry.data.releaseUrl || entry.data.repoUrl) && (
                            <div class="intel-asset-box">
                                <div class="asset-label">// PROJECT LINKS</div>
                                <div class="link-grid">
                                    {entry.data.releaseUrl && (
                                        <a href={entry.data.releaseUrl} target="_blank" class="asset-link-btn highlight">
                                            VIEW PROJECT >>
                                        </a>
                                    )}
                                    {entry.data.repoUrl && (
                                        <a href={entry.data.repoUrl} target="_blank" class="asset-link-btn">
                                            SOURCE CODE >>
                                        </a>
                                    )}
                                </div>
                            </div>
                        )}
                    </div>
                )}
            </div>
        </section>

        <section class="mil-border mission-body-full">
            <div class="content-warning">LOADING PROJECT DATA... DONE.</div>
            <div class="markdown-content">
                <Content />
            </div>
        </section>

        <div class="footer-actions">
            <a href={baseUrl} class="mil-border action-btn">CLOSE DETAILS</a>
        </div>
    </div>
</Layout>

<style>
    .mission-detail-container {
        padding-top: 20px;
        max-width: 1200px;
        margin: 0 auto;
    }

    .back-btn {
        display: inline-block;
        margin-bottom: 20px;
        font-size: 0.8rem;
        font-weight: bold;
        color: var(--accent-color);
        text-decoration: none;
    }

    .detail-header {
        margin-bottom: 30px;
        padding: 30px;
    }

    .header-top {
        display: flex;
        justify-content: space-between;
        margin-bottom: 15px;
    }

    .id {
        color: var(--accent-color);
        border: 1px solid var(--accent-color);
        padding: 2px 12px;
        font-weight: bold;
    }

    .type {
        padding: 2px 12px;
        font-weight: bold;
        color: #fff;
    }
    .type.solo { background: var(--military-purple); border: 1px solid var(--accent-color); box-shadow: 0 0 10px rgba(188, 76, 255, 0.3); }
    .type.team { background: #1e90ff; border: 1px solid #fff; }
    .type.other { background: #444; }

    h1 {
        font-size: 2.5rem;
        color: #fff;
        margin-bottom: 20px;
        letter-spacing: 0.05em;
    }

    .meta {
        font-size: 0.9rem;
        color: var(--text-sub);
    }

    .label { color: var(--accent-color); font-weight: bold; }

    /* Spec Sheet Styling */
    .spec-sheet {
        margin-top: 25px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        background: rgba(255, 255, 255, 0.03);
        padding: 15px;
        border-left: 2px solid var(--accent-color);
    }

    .spec-row {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    @media (max-width: 768px) {
        .spec-row {
            flex-direction: column;
            align-items: flex-start;
            gap: 8px;
        }
    }

    .spec-label {
        font-size: 0.65rem;
        font-weight: bold;
        color: var(--text-sub);
        min-width: 120px;
        letter-spacing: 0.1em;
    }

    .tags {
        display: flex;
        gap: 10px;
        flex-wrap: nowrap;
        overflow-x: auto;
        padding-bottom: 4px;
        -webkit-overflow-scrolling: touch;
        flex-grow: 1;
    }

    .tags::-webkit-scrollbar { height: 2px; }
    .tags::-webkit-scrollbar-thumb { background: rgba(188, 76, 255, 0.2); }

    .tag {
        flex: 0 0 auto;
        color: var(--accent-color);
        background: rgba(188, 76, 255, 0.1);
        border: 1px solid rgba(188, 76, 255, 0.3);
        padding: 2px 10px;
        font-size: 0.8rem;
        font-weight: bold;
        text-transform: uppercase;
    }

    .tag.stack::before { content: ":: "; opacity: 0.6; }
    
    .tag.tech {
        color: var(--accent-glow);
        background: rgba(188, 76, 255, 0.1);
        border-color: rgba(188, 76, 255, 0.3);
    }
    .tag.tech::before { content: "> "; opacity: 0.6; }

    .tag.tool {
        color: var(--text-sub);
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.1);
    }
    .tag.tool::before { content: "+ "; opacity: 0.6; }

    .mission-hero {
        margin-bottom: 30px;
        height: 400px;
        overflow: hidden;
        background: #000;
        border-color: rgba(188, 76, 255, 0.3);
    }

    .hero-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.9;
    }

    /* Intel Module Container */
    .intel-module {
        margin-bottom: 30px;
        background: rgba(26, 20, 20, 0.6);
        overflow: hidden;
        border-color: rgba(188, 76, 255, 0.3);
    }

    .intel-grid {
        display: grid;
        grid-template-columns: 1fr 400px;
        min-height: 350px;
    }

    @media (max-width: 992px) {
        .intel-grid {
            grid-template-columns: 1fr;
        }
    }

    .intel-main {
        padding: 30px;
        display: flex;
        flex-direction: column;
        border-right: 1px solid rgba(188, 76, 255, 0.2);
    }

    @media (max-width: 992px) {
        .intel-main {
            border-right: none;
            border-bottom: 1px solid rgba(188, 76, 255, 0.2);
        }
    }

    .intel-side {
        padding: 30px;
        background: rgba(0, 0, 0, 0.2);
        display: flex;
        flex-direction: column;
        gap: 25px;
    }

    .intel-asset-box {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .overview-content {
        font-size: 1.15rem;
        line-height: 1.8;
        color: var(--text-main);
        flex-grow: 1;
        display: block;
        padding-top: 10px;
        white-space: pre-wrap;
    }

    .asset-label {
        font-size: 0.7rem;
        font-weight: bold;
        color: var(--accent-color);
        letter-spacing: 0.1em;
        opacity: 0.8;
    }

    .video-container {
        position: relative;
        padding-bottom: 56.25%;
        height: 0;
        overflow: hidden;
        background: #000;
        border: 1px solid rgba(188, 76, 255, 0.2);
    }

    .video-container iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
    }

    .link-grid {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .asset-link-btn {
        display: block;
        padding: 12px;
        text-align: center;
        background: rgba(188, 76, 255, 0.05);
        border: 1px solid rgba(188, 76, 255, 0.3);
        color: var(--accent-color);
        text-decoration: none;
        font-size: 0.8rem;
        font-weight: bold;
        transition: all 0.3s ease;
    }

    .asset-link-btn:hover {
        background: rgba(188, 76, 255, 0.15);
        border-color: var(--accent-color);
        transform: translateY(-2px);
        box-shadow: 0 0 15px rgba(188, 76, 255, 0.3);
        color: #fff;
    }

    .asset-link-btn.highlight {
        background: var(--accent-color);
        color: #fff;
        border-color: var(--accent-color);
    }

    .asset-link-btn.highlight:hover {
        background: var(--accent-glow);
        box-shadow: 0 0 20px rgba(188, 76, 255, 0.5);
        color: var(--bg-color);
    }

    /* Body Full Section */
    .mission-body-full {
        padding: 40px;
        background: rgba(26, 20, 20, 0.4);
        margin-bottom: 40px;
        border-color: rgba(188, 76, 255, 0.3);
    }

    .content-warning {
        font-size: 0.7rem;
        color: var(--accent-color);
        margin-bottom: 30px;
        border-bottom: 1px solid rgba(188, 76, 255, 0.2);
        padding-bottom: 10px;
    }

    .markdown-content {
        line-height: 1.8;
        color: var(--text-main);
    }

    .markdown-content :global(p) { 
        margin-bottom: 20px; 
        white-space: pre-wrap;
    }
    .markdown-content :global(h2) { 
        color: var(--accent-color); 
        margin: 40px 0 20px; 
        border-bottom: 1px solid var(--accent-color);
    }

    .footer-actions {
        margin-top: 40px;
        text-align: center;
    }

    .action-btn {
        display: inline-block;
        padding: 15px 40px;
        font-weight: bold;
        color: var(--accent-color);
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .action-btn:hover {
        background: rgba(188, 76, 255, 0.1);
        box-shadow: 0 0 20px rgba(188, 76, 255, 0.3);
        color: #fff;
        transform: scale(1.05);
    }
</style>
