---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const missions = await getCollection("projects");
  return missions.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// BASE_URLの末尾に / があるかを確認し、無ければ付けます
let baseUrl = import.meta.env.BASE_URL;
if (!baseUrl.endsWith("/")) baseUrl += "/";
---

<Layout title={`${entry.data.title} - MISSION DETAILS`}>
    <div class="mission-detail-container">
        <a href={baseUrl} class="back-btn"><< RETURN TO HQ (HOME)</a>
        
        <header class="mil-border detail-header">
            <div class="header-top">
                <span class="id">{entry.data.projectCode}</span>
                <span class={`status ${entry.data.status.toLowerCase()}`}>{entry.data.status}</span>
            </div>
            <h1>{entry.data.title}</h1>
            <div class="meta">
                <span class="label">TIMESTAMP:</span> {entry.data.date}
                <div class="tags">
                    {entry.data.tags.map(tag => <span class="tag">{tag}</span>)}
                </div>
            </div>
        </header>

        {entry.data.thumbnail && (
            <div class="mission-hero mil-border">
                <img src={entry.data.thumbnail} alt={entry.data.title} class="hero-image" />
            </div>
        )}

        <section class="mil-border intel-module">
            <div class="intel-grid">
                <div class="intel-main">
                    <div class="asset-label">// MISSION OVERVIEW</div>
                    <div class="overview-content">
                        {entry.data.overview || entry.data.description}
                    </div>
                </div>

                {(entry.data.videoUrl || entry.data.releaseUrl || entry.data.repoUrl) && (
                    <div class="intel-side">
                        {entry.data.videoUrl && (
                            <div class="intel-asset-box">
                                <div class="asset-label">// INTEL VIDEO</div>
                                <div class="video-container">
                                    {entry.data.videoUrl.includes('youtube.com') || entry.data.videoUrl.includes('youtu.be') ? (
                                        <iframe 
                                            src={entry.data.videoUrl.replace('watch?v=', 'embed/').replace('youtu.be/', 'youtube.com/embed/')} 
                                            title="Mission Intel"
                                            frameborder="0" 
                                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                                            allowfullscreen
                                        ></iframe>
                                    ) : (
                                        <a href={entry.data.videoUrl} target="_blank" class="asset-link-btn">WATCH VIDEO >></a>
                                    )}
                                </div>
                            </div>
                        )}

                        {(entry.data.releaseUrl || entry.data.repoUrl) && (
                            <div class="intel-asset-box">
                                <div class="asset-label">// OPERATIONAL LINKS</div>
                                <div class="link-grid">
                                    {entry.data.releaseUrl && (
                                        <a href={entry.data.releaseUrl} target="_blank" class="asset-link-btn highlight">
                                            LAUNCH MISSION >>
                                        </a>
                                    )}
                                    {entry.data.repoUrl && (
                                        <a href={entry.data.repoUrl} target="_blank" class="asset-link-btn">
                                            SOURCE CODE >>
                                        </a>
                                    )}
                                </div>
                            </div>
                        )}
                    </div>
                )}
            </div>
        </section>

        <section class="mil-border mission-body-full">
            <div class="content-warning">ACCESSING CLASSIFIED DATA... DONE.</div>
            <div class="markdown-content">
                <Content />
            </div>
        </section>

        <div class="footer-actions">
            <a href={baseUrl} class="mil-border action-btn">CLOSE LOG</a>
        </div>
    </div>
</Layout>

<style>
    .mission-detail-container {
        padding-top: 20px;
        max-width: 1200px;
        margin: 0 auto;
    }

    .back-btn {
        display: inline-block;
        margin-bottom: 20px;
        font-size: 0.8rem;
        font-weight: bold;
        color: var(--warning-color);
        text-decoration: none;
    }

    .detail-header {
        margin-bottom: 30px;
        padding: 30px;
    }

    .header-top {
        display: flex;
        justify-content: space-between;
        margin-bottom: 15px;
    }

    .id {
        color: var(--accent-color);
        border: 1px solid var(--accent-color);
        padding: 2px 12px;
        font-weight: bold;
    }

    .status {
        padding: 2px 12px;
        font-weight: bold;
        color: #fff;
    }
    .status.active { background: #ff1212; box-shadow: 0 0 10px rgba(255, 18, 18, 0.5); }
    .status.completed { background: #1e90ff; }
    .status.archived { background: #888; }

    h1 {
        font-size: 2.5rem;
        color: #fff;
        margin-bottom: 20px;
        letter-spacing: 0.05em;
    }

    .meta {
        font-size: 0.9rem;
        color: var(--text-sub);
    }

    .label { color: var(--accent-color); font-weight: bold; }

    .tags {
        display: flex;
        gap: 10px;
        margin-top: 15px;
        flex-wrap: nowrap;
        overflow-x: auto;
        padding-bottom: 8px;
        -webkit-overflow-scrolling: touch;
    }

    .tags::-webkit-scrollbar { height: 3px; }
    .tags::-webkit-scrollbar-thumb { background: rgba(255, 18, 18, 0.3); }

    .tag {
        flex: 0 0 auto;
        color: var(--accent-color);
        background: rgba(255, 18, 18, 0.1);
        border: 1px solid rgba(255, 18, 18, 0.3);
        padding: 2px 10px;
        font-size: 0.8rem;
        font-weight: bold;
        text-transform: uppercase;
    }

    .tag::before {
        content: ":: ";
        opacity: 0.6;
    }

    .mission-hero {
        margin-bottom: 30px;
        height: 400px;
        overflow: hidden;
        background: #000;
    }

    .hero-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.9;
    }

    /* Intel Module Container */
    .intel-module {
        margin-bottom: 30px;
        background: rgba(26, 20, 20, 0.6);
        overflow: hidden;
    }

    .intel-grid {
        display: grid;
        grid-template-columns: 1fr 400px;
        min-height: 350px;
    }

    @media (max-width: 992px) {
        .intel-grid {
            grid-template-columns: 1fr;
        }
    }

    .intel-main {
        padding: 30px;
        display: flex;
        flex-direction: column;
        border-right: 1px solid rgba(255, 18, 18, 0.2);
    }

    @media (max-width: 992px) {
        .intel-main {
            border-right: none;
            border-bottom: 1px solid rgba(255, 18, 18, 0.2);
        }
    }

    .intel-side {
        padding: 30px;
        background: rgba(0, 0, 0, 0.2);
        display: flex;
        flex-direction: column;
        gap: 25px;
    }

    .intel-asset-box {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .overview-content {
        font-size: 1.15rem;
        line-height: 1.8;
        color: var(--text-main);
        flex-grow: 1;
        display: block;
        padding-top: 10px;
        white-space: pre-wrap;
    }

    .asset-label {
        font-size: 0.7rem;
        font-weight: bold;
        color: var(--accent-color);
        letter-spacing: 0.1em;
        opacity: 0.8;
    }

    .video-container {
        position: relative;
        padding-bottom: 56.25%;
        height: 0;
        overflow: hidden;
        background: #000;
        border: 1px solid rgba(255, 18, 18, 0.2);
    }

    .video-container iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
    }

    .link-grid {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .asset-link-btn {
        display: block;
        padding: 12px;
        text-align: center;
        background: rgba(255, 18, 18, 0.05);
        border: 1px solid rgba(255, 18, 18, 0.3);
        color: var(--accent-color);
        text-decoration: none;
        font-size: 0.8rem;
        font-weight: bold;
        transition: all 0.3s ease;
    }

    .asset-link-btn:hover {
        background: rgba(255, 18, 18, 0.15);
        border-color: var(--accent-color);
        transform: translateY(-2px);
        box-shadow: 0 0 15px rgba(255, 18, 18, 0.3);
        color: #fff;
    }

    .asset-link-btn.highlight {
        background: var(--accent-color);
        color: #fff;
        border-color: var(--accent-color);
    }

    .asset-link-btn.highlight:hover {
        background: #ff4545;
        box-shadow: 0 0 20px rgba(255, 18, 18, 0.5);
    }

    /* Body Full Section */
    .mission-body-full {
        padding: 40px;
        background: rgba(26, 20, 20, 0.4);
        margin-bottom: 40px;
    }

    .content-warning {
        font-size: 0.7rem;
        color: var(--accent-color);
        margin-bottom: 30px;
        border-bottom: 1px solid rgba(255, 18, 18, 0.2);
        padding-bottom: 10px;
    }

    .markdown-content {
        line-height: 1.8;
        color: var(--text-main);
    }

    .markdown-content :global(p) { 
        margin-bottom: 20px; 
        white-space: pre-wrap;
    }
    .markdown-content :global(h2) { 
        color: var(--accent-color); 
        margin: 40px 0 20px; 
        border-bottom: 1px solid var(--accent-color);
    }

    .footer-actions {
        margin-top: 40px;
        text-align: center;
    }

    .action-btn {
        display: inline-block;
        padding: 15px 40px;
        font-weight: bold;
        color: var(--accent-color);
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .action-btn:hover {
        background: rgba(255, 18, 18, 0.1);
        box-shadow: 0 0 20px rgba(255, 18, 18, 0.3);
        color: #fff;
        transform: scale(1.05);
    }
</style>
