---
import Header from "../components/Header.astro";
const { title = "八幡拓音 - Portfolio" } = Astro.props;
let baseUrl = import.meta.env.BASE_URL; // "/HIBIKI5201/" になります
if (!baseUrl.endsWith("/")) baseUrl += "/";
---
<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
		<link rel="icon" href={`${baseUrl}favicon.ico`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;700&family=Oxanium:wght@300;400;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
		<noscript>
			<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;700&family=Oxanium:wght@300;400;700&display=swap" rel="stylesheet">
		</noscript>
	</head>
	<body>
		<Header />
		<div class="overlay"></div>
		<main>
			<slot />
		</main>
	</body>
</html>

<style is:global>
	:root {
		--bg-color: #0a0a0a; /* 純粋な黒に近いグレー */
		--panel-color: #151515;
		--accent-color: #9d4edd; /* 落ち着いた、しかし存在感のある紫 */
		--accent-color-rgb: 157, 78, 221;
		--accent-glow: #c77dff;
		--warning-color: #555555; /* 警告やサブ要素はグレーで抑える */
		--text-main: #e0e0e0;
		--text-sub: #888888;
		--military-purple: #1a1a1a; /* ここもモノトーンに */
		--border-style: 1px solid rgba(var(--accent-color-rgb), 0.3);
	}

	html, body {
		margin: 0;
		padding: 0;
		width: 100%;
		min-height: 100%;
		background-color: var(--bg-color);
		color: var(--text-main);
		font-family: "JetBrains Mono", monospace;
		overflow-x: hidden;
		scroll-behavior: smooth;
	}

	body {
		/* グリッドも紫を抑えて白の微かな線に */
		background-image: 
			linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
		background-size: 40px 40px;
	}

	.overlay {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		/* オーバーレイの紫のグラデーションも削除し、スキャンラインのみに */
		background: linear-gradient(rgba(10, 10, 10, 0) 50%, rgba(0, 0, 0, 0.15) 50%);
		background-size: 100% 4px;
		pointer-events: none;
		z-index: 100;
		opacity: 0.3;
	}

	h1, h2, h3 {
		font-family: "Oxanium", sans-serif;
		text-transform: uppercase;
		letter-spacing: 2px;
		margin: 0;
	}

	main {
		max-width: 1000px;
		margin: 0 auto;
		padding: 100px 20px 40px;
		position: relative;
		z-index: 1;
	}

	.mil-border {
		border: var(--border-style);
		padding: 20px;
		position: relative;
		background: rgba(18, 18, 18, 0.9); /* 赤み(26,20,20)を排除 */
		backdrop-filter: blur(4px);
	}

	.mil-border::before {
		content: "";
		position: absolute;
		top: -5px;
		left: -5px;
		width: 20px;
		height: 20px;
		border-top: 2px solid var(--accent-color);
		border-left: 2px solid var(--accent-color);
	}

	.mil-border::after {
		content: "";
		position: absolute;
		bottom: -5px;
		right: -5px;
		width: 20px;
		height: 20px;
		border-bottom: 2px solid var(--accent-color);
		border-right: 2px solid var(--accent-color);
	}

	section {
		margin-bottom: 60px;
	}

	a {
		color: var(--accent-color);
		text-decoration: none;
		transition: all 0.3s ease;
	}

	a:hover {
		color: #fff;
		text-shadow: 0 0 10px var(--accent-color);
	}

	::-webkit-scrollbar {
		width: 8px;
	}

	::-webkit-scrollbar-track {
		background: var(--bg-color);
	}

	::-webkit-scrollbar-thumb {
		background: var(--military-purple);
		border: 1px solid var(--accent-color);
	}
</style>
