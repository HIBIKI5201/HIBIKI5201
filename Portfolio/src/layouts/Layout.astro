---
const { title = "八幡拓音 - Portfolio" } = Astro.props;
let baseUrl = import.meta.env.BASE_URL; // "/HIBIKI5201/" になります
if (!baseUrl.endsWith("/")) baseUrl += "/";
---
<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
		<link rel="icon" href={`${baseUrl}favicon.ico`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;700&family=Oxanium:wght@300;400;700&display=swap" rel="stylesheet">
	</head>
	<body>
		<div class="overlay"></div>
		<main>
			<slot />
		</main>
	</body>
</html>

<style is:global>
	:root {
		--bg-color: #0f0a0a;
		--panel-color: #1a1414;
		--accent-color: #ff1212;
		--warning-color: #ff8c00;
		--text-main: #e0e0e0;
		--text-sub: #a08888;
		--military-red: #5e1919;
		--border-style: 1px solid rgba(255, 18, 18, 0.3);
	}

	html, body {
		margin: 0;
		padding: 0;
		width: 100%;
		min-height: 100%;
		background-color: var(--bg-color);
		color: var(--text-main);
		font-family: "JetBrains Mono", monospace;
		overflow-x: hidden;
	}

	body {
		background-image: 
			linear-gradient(rgba(255, 18, 18, 0.05) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 18, 18, 0.05) 1px, transparent 1px);
		background-size: 40px 40px;
	}

	.overlay {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: linear-gradient(rgba(18, 10, 10, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(255, 140, 0, 0.02), rgba(255, 0, 0, 0.06));
		background-size: 100% 4px, 3px 100%;
		pointer-events: none;
		z-index: 100;
		opacity: 0.2;
	}

	h1, h2, h3 {
		font-family: "Oxanium", sans-serif;
		text-transform: uppercase;
		letter-spacing: 2px;
		margin: 0;
	}

	main {
		max-width: 1000px;
		margin: 0 auto;
		padding: 40px 20px;
		position: relative;
		z-index: 1;
	}

	.mil-border {
		border: var(--border-style);
		padding: 20px;
		position: relative;
		background: rgba(26, 20, 20, 0.8);
		backdrop-filter: blur(4px);
	}

	.mil-border::before {
		content: "";
		position: absolute;
		top: -5px;
		left: -5px;
		width: 20px;
		height: 20px;
		border-top: 2px solid var(--accent-color);
		border-left: 2px solid var(--accent-color);
	}

	.mil-border::after {
		content: "";
		position: absolute;
		bottom: -5px;
		right: -5px;
		width: 20px;
		height: 20px;
		border-bottom: 2px solid var(--accent-color);
		border-right: 2px solid var(--accent-color);
	}

	section {
		margin-bottom: 60px;
	}

	a {
		color: var(--accent-color);
		text-decoration: none;
		transition: all 0.3s ease;
	}

	a:hover {
		color: #fff;
		text-shadow: 0 0 10px var(--accent-color);
	}

	::-webkit-scrollbar {
		width: 8px;
	}

	::-webkit-scrollbar-track {
		background: var(--bg-color);
	}

	::-webkit-scrollbar-thumb {
		background: var(--military-red);
		border: 1px solid var(--accent-color);
	}
</style>
